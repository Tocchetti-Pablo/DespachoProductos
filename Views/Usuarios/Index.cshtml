@model IEnumerable<AppWebDespachos.Models.Usuario>

@{
    ViewData["Title"] = "ABM Usuarios";
}

<h1>ABM USUARIOS</h1>


<p class="mt-5 mb-5">
    <a asp-action="Create" class="btn btn-success">Nuevo Usuario</a>
</p>
<h3 class="fw-bold text-center">LISTA DE USUARIOS</h3>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Nombre)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Apellido)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Email)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.User)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Password)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Habilitado)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Rol)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Nombre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Apellido)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Email)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.User)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Password)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Habilitado)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Rol.Nombre)
                </td>
                <td>
                    <div class="d-flex gap-1">
                            <a asp-action="Edit" asp-route-id="@item.Id_usuario" class="btn btn-warning btn-sm me-1 w-auto">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.Id_usuario" class="btn btn-secondary btn-sm me-1 w-auto text-white">Ver detalles</a>
                        @if (item.Habilitado)
                        {
                                <a asp-action="Edit" asp-route-id="@item.Id_usuario" class="btn btn-danger btn-sm w-auto">Inhabilitar</a>
                        }
                        else
                        {
                        <span class="badge bg-secondary">Inhabilitado</span>
                        }
                    </div>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
