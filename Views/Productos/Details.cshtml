@model AppWebDespachos.Models.Producto

@{
    ViewData["Title"] = "Detalles";
}

<h1>DATOS PRODUCTO</h1>
<h3 class="fw-bold text-center">Detalles del producto</h3>
<hr />
<div>

    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nombre)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nombre)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Descripcion)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Descripcion)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Stock)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Stock)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Precio_unitario)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Precio_unitario)
        </dd>

        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Usuario)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Usuario.Apellido)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Habilitado)
        </dt>
        <dd class="col-sm-10">
            @(Model.Habilitado ? "Sí" : "No")
        </dd>

    </dl>
</div>
<div class="d-flex m-2">
    <a asp-action="Edit" asp-route-id="@Model?.Id_producto" class="btn btn-primary me-1">Editar</a>
    <a asp-action="Index" class="btn btn-secondary me-1">Regresar a la lista de clientes</a>
</div>
